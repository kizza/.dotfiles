#!/usr/bin/env bash

set -euo pipefail

die() { echo "$*" >&2; exit 1; }

case "${1:-}" in
    # List the branches within the latest deploy (running or otherwise)
    latest)
        # Get that most recent deploy action (running or otherwise), and select its SHA
        read STATUS SHA <<< $(gh run list --workflow=deploy.yml --limit=1 --json status,headSha | jq -r '.[0] | "\(.status) \(.headSha)"')
        # Fetch origin if required (ie. to have sha context available)
        git cat-file -e $SHA 2>/dev/null || git fetch origin main --quiet
        # Show merge commits within this HSA
        echo "The latest deploy is $STATUS and contains:"
        git log --merges --oneline --max-count=10 origin/main $SHA
        ;;

    # List the latest 10 builds (ie. merges into mani)
    builds)
        gh run list --workflow=main.yml --branch=main --limit=10
        ;;

    # List the latest 10 deploys
    deploys)
        gh run list --workflow=deploy.yml --limit=10
        ;;

    "")
        # Ensure we have latest main for context
        LOCAL=$(git rev-parse origin/main 2>/dev/null)
        REMOTE=$(git ls-remote origin refs/heads/main | cut -f1)
        [ "$LOCAL" != "$REMOTE" ] && git fetch origin main --quiet

        # Find your recently merged branches
        YOUR_NAME="$(git config user.name)"
        MERGE_SHA=$(git log --merges --first-parent --since=1.weeks.ago --pretty="%h %ad %an %s" --date=short origin/main \
          | grep -F "$YOUR_NAME" \
          | sed -E -n 's/([^ ]+) ([^ ]+) .*? from ([^ ]+)/\1 → \3 (\2)/p' \
          | fzf \
          | cut -d ' ' -f 1)

         echo "Using merge sha $MERGE_SHA"

         # Get last 10 builds with headSha, status, displayTitle — oldest first
         RUNS=$(gh run list --workflow=main.yml --branch=main --limit=10 --json headSha,status,displayTitle | jq -r '[.[] | "\(.headSha) \(.status) \(.displayTitle)"] | reverse | .[]')
         while IFS= read -r line; do
          # Assign run attributes from line
          read -r SHA STATUS TITLE <<< "$line"

          # See if merge commit sha is within run sha
          if git merge-base --is-ancestor "$MERGE_SHA" "$SHA" 2>/dev/null; then
              echo "✓ Found in build: [$STATUS] $TITLE ($SHA)"
              break
          fi
        done <<< "$RUNS"

        # Get last 10 builds with headSha, status, displayTitle — oldest first
        RUNS=$(gh run list --workflow=deploy.yml --limit=10 --json headSha,status,displayTitle | jq -r '[.[] | "\(.headSha) \(.status) \(.displayTitle)"] | reverse | .[]')
        while IFS= read -r line; do
          # Assign run attributes from line
          read -r SHA STATUS TITLE <<< "$line"

          # See if merge commit sha is within run sha
          if git merge-base --is-ancestor "$MERGE_SHA" "$SHA" 2>/dev/null; then
              echo "✓ Found in deploy: [$STATUS] $TITLE ($SHA)"
              break
          fi
        done <<< "$RUNS"
        ;;

    *)
        die "Unknown command: $1"
        ;;
esac
