#!/usr/bin/env bash
set -euo pipefail

echo "Scanning for node_modules below: $(pwd)"
echo

dirs=$(find . -type d -name node_modules -prune | sort)

if [ -z "$dirs" ]; then
  echo "No node_modules directories found."
  exit 0
fi

echo "Space used by each node_modules:"
echo "$dirs" | xargs du -sh | sort -h
echo

total=$(echo "$dirs" | xargs du -sch | tail -n 1)
echo "Total: $total"
echo

read -r -p "Delete ALL of these node_modules directories? Type Y to confirm: " answer

if [ "$answer" = "Y" ]; then
  echo "$dirs" | while IFS= read -r dir; do
    echo "Removing $dir"
    rm -rf -- "$dir"
  done
  echo "Done."
else
  echo "Cancelled."
fi
